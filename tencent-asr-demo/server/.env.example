# Required: Tencent Cloud ASR
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_APP_ID=

# Optional: temporary token if you use Tencent STS credentials
TENCENT_TOKEN=

# Server
PORT=3002
CLIENT_ORIGIN=http://localhost:5173

# Tencent ASR options
TENCENT_ENGINE_MODEL_TYPE=16k_zh
TENCENT_VOICE_FORMAT=1
TENCENT_URL_EXPIRE_SECONDS=86400

# Optional: smart polishing through OpenAI-compatible API, e.g. DashScope/Qwen
DASHSCOPE_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
