# 阿里云百炼 API Key，不要提交真实 Key
DASHSCOPE_API_KEY=sk-your-api-key

# 后端端口
PORT=3001

# 阿里云地域：cn | intl | us
DASHSCOPE_REGION=cn

# 实时语音识别模型
ASR_MODEL=qwen3-asr-flash-realtime

# 文本整理模型
LLM_MODEL=qwen-plus

# 默认识别语言：zh, en, yue 等
DEFAULT_LANGUAGE=zh

# 当前 demo 使用 Manual 模式，停止时由前端控制断句

# 打印 ASR 事件摘要，不包含音频内容或 API Key
DEBUG_ASR_EVENTS=true
