# Optional: copy this file to .env if you do not want to reuse ../tencent-asr-demo/server/.env
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_APP_ID=

# Optional: temporary token if you use Tencent STS credentials
TENCENT_TOKEN=

# Server
PORT=3003

# Tencent realtime speaker diarization options
TENCENT_SPEAKER_ENGINE_MODEL_TYPE=16k_zh_en_speaker
TENCENT_VOICE_FORMAT=1
TENCENT_SENTENCE_STRATEGY=0
TENCENT_URL_EXPIRE_SECONDS=86400
